# Orchestrator Environment Variables (Railway)
# Copy this to your Railway service environment

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OpenAI
OPENAI_API_KEY=

# Supabase (for writing call data)
SUPABASE_URL=https://dtctqwoesbvntdpeekgv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public URLs (for Twilio webhooks)
PUBLIC_BASE_URL=
PUBLIC_WS_BASE_URL=

# Azure Maps (for location confirmation reverse geocoding)
AZURE_MAPS_KEY=

# Azure Storage Static Website endpoint hosting the location confirmation page
# (no trailing slash, e.g. https://rescueboy.z6.web.core.windows.net)
AZURE_STATIC_BASE_URL=

# HMAC secret for signing location-confirmation tokens (openssl rand -hex 32)
LOCATION_TOKEN_SECRET=

# Optional
NODE_ENV=production
PORT=3000
