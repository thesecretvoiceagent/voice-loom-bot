# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OpenAI
OPENAI_API_KEY=

# Supabase (for writing call data)
SUPABASE_URL=https://dtctqwoesbvntdpeekgv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public URLs (for Twilio webhooks — set to your Railway domain)
PUBLIC_BASE_URL=
PUBLIC_WS_BASE_URL=

# Azure Maps (server-side reverse geocoding for location confirmation page)
AZURE_MAPS_KEY=

# Static page hosting (Azure Storage Static Website primary endpoint, no trailing slash)
# e.g. https://rescueboy.z6.web.core.windows.net
AZURE_STATIC_BASE_URL=

# HMAC secret for signing/verifying location confirmation tokens
# Generate: openssl rand -hex 32
LOCATION_TOKEN_SECRET=

# Server
PORT=3000
NODE_ENV=production
